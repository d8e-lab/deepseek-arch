# Maintainer: helcksun <helcksun@users.noreply.github.com>
# Contributor: d8e <d8e@users.noreply.github.com>
#
# Build: ./scripts/build-prebuilt-tarball.sh → upload to GitHub Release → update sha256sums

pkgname=deepseek-arch
pkgver=1.3.6
pkgrel=1
pkgdesc="Terminal AI agent with Agent Loop, Tool Calling, streaming, persistent storage and browser tools"
arch=('any')
options=(!strip)
url="https://github.com/d8e-lab/deepseek-arch"
license=('MIT')
depends=('nodejs>=18')
optdepends=(
	'chromium: browser tools (Playwright)'
	'git: version control integration'
	'ripgrep: enhanced file search'
)
install="${pkgname}.install"
source=("${pkgname}-${pkgver}-prebuilt.tar.gz::${url}/releases/download/v${pkgver}/${pkgname}-${pkgver}-prebuilt.tar.gz")
sha256sums=('2da5d7ec90915457c188748b4ee629575c602cb8326b27766c28910856522841')

package() {
	cd "${srcdir}"

	local moddir="${pkgdir}/usr/lib/node_modules/${pkgname}"
	install -dm755 "${moddir}"

	cp -r dist node_modules package.json "${moddir}/"
	cp -r skill "${moddir}/"
	cp README.md system_prompt.txt "${moddir}/"

	install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"

	install -dm755 "${pkgdir}/usr/bin"
	cat > "${pkgdir}/usr/bin/${pkgname}" << 'EOF'
#!/bin/sh
export NODE_ENV=production
exec node /usr/lib/node_modules/deepseek-arch/dist/cli/index.js "$@"
EOF
	chmod 755 "${pkgdir}/usr/bin/${pkgname}"
}
