{
  "name": "deepseek-arch",
  "version": "1.0.1",
  "description": "DeepSeek Terminal Agent — Linux 终端 AI 助手，支持多轮对话、Agent Loop、Tool Calling 与持久化存储",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./core": "./dist/core/index.js",
    "./types": "./dist/types/index.js"
  },
  "bin": {
    "deepseek-arch": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/d8e-lab/deepseek-arch.git"
  },
  "homepage": "https://github.com/d8e-lab/deepseek-arch#readme",
  "bugs": {
    "url": "https://github.com/d8e-lab/deepseek-arch/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepack": "npm run build:release",
    "build:release": "tsc -p tsconfig.release.json"
  },
  "keywords": [
    "deepseek",
    "ai",
    "terminal",
    "agent",
    "cli",
    "tool-calling"
  ],
  "author": "helcksun",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "smol-toml": "^1.6.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
