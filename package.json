{
  "name": "deepseek-arch",
  "version": "0.1.0",
  "description": "DeepSeek core library，提供会话、存储、配置与模型调用能力",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./core": "./dist/core/index.js",
    "./types": "./dist/types/index.js"
  },
  "bin": {
    "deepseek-arch": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "deepseek",
    "ai",
    "library",
    "sdk",
    "core"
  ],
  "author": "helcksun",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "smol-toml": "^1.6.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
